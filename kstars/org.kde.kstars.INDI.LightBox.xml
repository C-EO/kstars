<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN" "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
    <interface name="org.kde.kstars.INDI.LightBox">
        <property name="name" type="s" access="read"/>
        <property name="connected" type="b" access="read"/>
        <property name="status" type="i" access="read">
            <annotation name="org.qtproject.QtDBus.QtTypeName" value="ISD::LightBox::LightStatus"/>
        </property>
        <property name="brightness" type="q" access="read"/>
        <method name="isLightOn">
            <arg type="b" direction="out"/>
        </method>
        <method name="setLightEnabled">
            <arg type="b" direction="out"/>
            <arg name="enable" type="b" direction="in"/>
        </method>
        <method name="setBrightness">
            <arg type="b" direction="out"/>
            <arg name="val" type="q" direction="in"/>
        </method>
        <signal name="Connected"/>
        <signal name="Disconnected"/>
        <signal name="ready"/>
        <signal name="newStatus">
            <arg name="status" type="(i)" direction="out"/>
            <annotation name="org.qtproject.QtDBus.QtTypeName.In0" value="ISD::LightBox::LightStatus"/>
            <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="ISD::LightBox::LightStatus"/>
        </signal>
    </interface>
</node>